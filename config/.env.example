# All variables are auto-detected by claude-docker-ctrl.
# Only set these if you need to override the defaults.

# HOST_USER=              # default: $(whoami)
# HOST_UID=               # default: $(id -u)
# GITHUB_TOKEN=            # default: $(gh auth token)
# GIT_USER_NAME=          # default: $(git config user.name)
# GIT_USER_EMAIL=         # default: $(git config user.email)
# GIT_PROTECTED_BRANCHES=main master
# GOPRIVATE=
# GONOSUMDB=                # default: same as GOPRIVATE
# SSH agent forwarding is auto-detected from SSH_AUTH_SOCK — no config needed.
